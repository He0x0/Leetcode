# ---------------------------------
# C/C++ LeetCode Project .gitignore
# ---------------------------------

# 忽略所有子目录中名为 "test" 的可执行文件
# 这会匹配 Part1/s1/test, Part2/s2/test 等等
test

# 忽略所有编译生成的中间目标文件 (.o)
*.o

# 忽略 C++ 编译器可能生成的依赖文件
*.d

# 忽略调试文件 (例如 macOS 上的 .dSYM 文件夹)
*.dSYM/

# 特定于IDE/编辑器的配置文件
.vscode/
.idea/
*.swp
*~

# 特定于操作系统的文件
.DS_Store
Thumbs.db